# Configurações do Backend - MKS Service

# Porta do servidor (padrão Cloud Run é 8080)
PORT=8080

# ID do Projeto Firebase (Google Cloud)
# Atualize com seu projectId se for diferente
GOOGLE_CLOUD_PROJECT=mksservice-71367430-58374

# Google Sheets Spreadsheet IDs
# (Atualmente o código usa IDs fixos, mas sinta-se à vontade para movê-los para cá)
# SPREADSHEET_ID_NFE=...
# SPREADSHEET_ID_ESTOQUE=...

# URLs Externas
# BLING_API_BASE_URL=https://api.bling.com.br/Api/v3

# Bling Webhook Authentication
BLING_CLIENT_SECRET=seu_client_secret_aqui
